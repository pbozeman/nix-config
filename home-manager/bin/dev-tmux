#! /usr/bin/env bash

set -euo pipefail

dir="$(pwd)"
name="${1:-$(basename "$dir")}"

codex_cmd="sandbox codex --dangerously-bypass-approvals-and-sandbox"

nvim_pane=$(tmux display-message -p '#{pane_id}')

tmux rename-window "$name"
tmux set-environment TMUX_WN_MANUAL 1
codex_pane=$(tmux split-window -h -c "$dir" -P -F '#{pane_id}')
shell_pane=$(tmux split-window -v -c "$dir" -P -F '#{pane_id}')

tmux send-keys -t "$nvim_pane" 'nvim' Enter
tmux send-keys -t "$codex_pane" "set -x MAKEFLAGS -j(math (nproc) - 2) ; clear ; $codex_cmd" Enter
tmux send-keys -t "$shell_pane" 'set -x MAKEFLAGS -j(nproc) ; clear' Enter
tmux select-pane -t "$codex_pane"
