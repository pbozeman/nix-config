#! /usr/bin/env bash

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: gwta <name> [branch]" >&2
  exit 1
fi

name="$1"
dest="$HOME/src/$name"

# Pure worktree creation (add, push to dev, submodules, copy extras, direnv allow).
git-worktree-add "$@"

# Dev env: open a tmux window in the worktree, then lay out nvim / agent / shell.
cd "$dest"
tmux new-window -c "$dest"
dev-tmux "$name"
