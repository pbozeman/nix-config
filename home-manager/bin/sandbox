#!/usr/bin/env bash
set -e

PROJECT_DIR="$(pwd)"

# Extra mount points: CLI flags and SANDBOX_EXTRA_BINDS env var.
#   -b/--bind DIR     mount DIR read-write at the same path inside the sandbox
#   --ro-bind DIR     mount DIR read-only
#   --                end of sandbox flags; remainder is the command
# SANDBOX_EXTRA_BINDS is a colon-separated list of rw paths (use $HOME/...,
# not ~, since callers like direnv do not expand tildes).
extra_binds=()
add_bind()    { [[ -e "$1" ]] && extra_binds+=("--bind"    "$1" "$1") || echo "sandbox: skipping missing $1" >&2; }
add_ro_bind() { [[ -e "$1" ]] && extra_binds+=("--ro-bind" "$1" "$1") || echo "sandbox: skipping missing $1" >&2; }

while [[ $# -gt 0 ]]; do
  case "$1" in
    -b|--bind)  [[ -n "${2:-}" ]] || { echo "sandbox: $1 requires a path" >&2; exit 2; }; add_bind    "$2"; shift 2 ;;
    --ro-bind)  [[ -n "${2:-}" ]] || { echo "sandbox: $1 requires a path" >&2; exit 2; }; add_ro_bind "$2"; shift 2 ;;
    --)         shift; break ;;
    -*)         echo "sandbox: unknown flag $1" >&2; exit 2 ;;
    *)          break ;;
  esac
done

if [[ -n "${SANDBOX_EXTRA_BINDS:-}" ]]; then
  IFS=: read -ra _env_binds <<<"$SANDBOX_EXTRA_BINDS"
  for d in "${_env_binds[@]}"; do [[ -n "$d" ]] && add_bind "$d"; done
fi

# Build env args from current environment
env_args=()
while IFS='=' read -r -d '' name value; do
  # Skip problematic vars
  [[ "$name" =~ ^(PWD|OLDPWD|SHLVL|_|TERM_SESSION_ID|BASH_FUNC_.*)$ ]] && continue
  # Skip empty names or values with newlines
  [[ -z "$name" ]] && continue
  [[ "$value" == *$'\n'* ]] && continue
  env_args+=("--setenv" "$name" "$value")
done < <(env -0)

# Home-manager paths to bind (read-only).
# ~/.bazelrc is the home rc that sets --disk_cache; without it bazel inside
# the sandbox never reads the (bound) disk cache, so builds don't share it.
hm_args=()
for hm_path in "$HOME/.nix-profile" "/etc/profiles/per-user/$USER" "$HOME/bin" "$HOME/.bazelrc"; do
  if [[ -e "$hm_path" ]]; then
    hm_args+=("--ro-bind" "$hm_path" "$hm_path")
  fi
done

# Git global config (home-manager symlinks into /nix/store)
git_config_args=()
if [[ -d "$HOME/.config/git" ]]; then
  git_config_args+=("--ro-bind" "$HOME/.config/git" "$HOME/.config/git")
fi

# Tool cache/state paths that need to be writable inside the sandbox.
cache_args=()
for cache_dir in "$HOME/.cache/bazel" "$HOME/.cache/bazel-disk" "$HOME/.local/share/direnv"; do
  mkdir -p "$cache_dir"
  cache_args+=("--bind" "$cache_dir" "$cache_dir")
done

# Git submodule/worktree support - bind the actual git dir if .git is a file
git_args=()
if [[ -f "$PROJECT_DIR/.git" ]]; then
  # Parse gitdir from the .git file
  gitdir=$(sed -n 's/^gitdir: //p' "$PROJECT_DIR/.git")
  if [[ -n "$gitdir" ]]; then
    # Resolve relative path
    if [[ "$gitdir" != /* ]]; then
      gitdir="$PROJECT_DIR/$gitdir"
    fi
    gitdir=$(cd "$PROJECT_DIR" && cd "$(dirname "$gitdir")" && pwd)/$(basename "$gitdir")
    if [[ -d "$gitdir" ]]; then
      git_args+=("--bind" "$gitdir" "$gitdir")
      # For worktrees, also need the main .git directory
      # worktree gitdir contains a 'commondir' file pointing to main repo
      if [[ -f "$gitdir/commondir" ]]; then
        commondir=$(cat "$gitdir/commondir")
        if [[ "$commondir" != /* ]]; then
          commondir="$gitdir/$commondir"
        fi
        commondir=$(cd "$(dirname "$commondir")" && pwd)/$(basename "$commondir")
        if [[ -d "$commondir" ]]; then
          git_args+=("--bind" "$commondir" "$commondir")
        fi
      fi
    fi
  fi
fi

exec bwrap \
  --ro-bind /nix/store /nix/store \
  --ro-bind /run/current-system /run/current-system \
  --ro-bind /etc/resolv.conf /etc/resolv.conf \
  --ro-bind /etc/ssl /etc/ssl \
  --ro-bind /etc/static /etc/static \
  --ro-bind /etc/hosts /etc/hosts \
  --ro-bind /usr /usr \
  --ro-bind /bin /bin \
  --symlink /usr/lib /lib \
  --symlink /usr/lib64 /lib64 \
  --proc /proc \
  --dev /dev \
  --tmpfs /tmp \
  --tmpfs "$HOME" \
  "${hm_args[@]}" \
  "${git_config_args[@]}" \
  "${cache_args[@]}" \
  --bind "$HOME/.claude" "$HOME/.claude" \
  --bind "$HOME/.claude.json" "$HOME/.claude.json" \
  --bind "$HOME/.codex" "$HOME/.codex" \
  --bind "$PROJECT_DIR" "$PROJECT_DIR" \
  "${git_args[@]}" \
  "${extra_binds[@]}" \
  --chdir "$PROJECT_DIR" \
  --die-with-parent \
  "${env_args[@]}" \
  --setenv PWD "$PROJECT_DIR" \
  "${@:-bash}"
